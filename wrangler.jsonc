{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "ciclicoscript",
  "main": "src/index.ts",
  "compatibility_date": "2025-06-01",
  "compatibility_flags": ["nodejs_compat"],

  // Dashboard estático (panel de control). El Worker maneja /api/* ;
  // cualquier otra ruta sirve un archivo de ./public (index.html en /).
  "assets": {
    "directory": "./public",
    "binding": "ASSETS"
  },

  // Almacenamiento de las imágenes del banner.
  "r2_buckets": [
    {
      "binding": "BANNERS",
      "bucket_name": "ciclico-banners"
    }
  ],

  // Tareas programadas. El rotador corre cada 2 horas; el calendario interno
  // (editable desde el dashboard) decide qué imagen poner según el día.
  // Para acotar a ciertas horas, cambiá la expresión (ej. "0 8-22/2 * * *").
  "triggers": {
    "crons": ["0 */2 * * *"]
  },

  // Variables públicas (NO secretos). Los secretos se cargan con
  // `wrangler secret put` — ver README.
  "vars": {
    "YOUTUBE_CHANNEL_ID": "UC_lnf3whd4UOM0Vnbw-pkeA",
    "ROTATOR_ENABLED": "true"
  },

  "observability": {
    "enabled": true
  }
}
